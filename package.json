{
  "name": "ultra-igdl",
  "version": "1.0.0",
  "description": "Production-grade Instagram media extractor for Node.js — reels, posts, carousels, stories, highlights. Multi-layer parsing, session API, CLI, ESM+CJS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ultra-igdl": "./dist/cli/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:stress": "vitest run --config vitest.stress.config.ts",
    "lint": "tsc --noEmit",
    "cli": "node ./dist/cli/index.cjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "instagram",
    "instagram-downloader",
    "instagram-media",
    "reels",
    "reel-downloader",
    "stories",
    "carousel",
    "sidecar",
    "highlights",
    "media-extractor",
    "undici",
    "typescript",
    "cli"
  ],
  "author": "WH173 5P1D3R",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WH173-5P1D3R/ultra-igdl.git"
  },
  "bugs": {
    "url": "https://github.com/WH173-5P1D3R/ultra-igdl/issues"
  },
  "homepage": "https://github.com/WH173-5P1D3R/ultra-igdl#readme",
  "dependencies": {
    "cheerio": "^1.0.0",
    "lru-cache": "^11.0.2",
    "undici": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.2"
  }
}